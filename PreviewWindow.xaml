<Window x:Class="WingForce.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCU Display Preview"
        Width="860"
        Height="620"
        MinWidth="760"
        MinHeight="520"
        Background="#FF161616"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="MCU Display Preview" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Preview uses the current PC values and configuration before you write anything to the MCU." Margin="0,6,0,0" Foreground="#FFD0D0D0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Viewbox Stretch="Uniform" Margin="0,0,16,0">
                <Border Background="#FF050505" BorderBrush="#FF404040" BorderThickness="1" Padding="10">
                    <Grid x:Name="DisplayRoot" Width="480" Height="320">
                        <Grid.LayoutTransform>
                            <RotateTransform x:Name="DisplayRotationTransform" Angle="0"/>
                        </Grid.LayoutTransform>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="207"/>
                                <RowDefinition Height="58"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="336"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="TitleBar" Grid.Row="0" Grid.ColumnSpan="2" Background="#FF5A5A5A">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TitleLeftText" Grid.Column="0" Text="WING STUDIO" FontSize="22" Foreground="#FF5CFF5C" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TitleRightText" Grid.Column="1" Text="12V-2X6 Ti" FontSize="22" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border x:Name="ChannelSection" Grid.Row="1" Grid.Column="0" Background="#FF202020" Margin="0,0,12,12" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ChannelIndicator0" Width="16" Height="16" Background="#FF00C800" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelLabel0" Grid.Column="1" Text="CH-A :" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelVoltage0" Grid.Column="2" Text=" 00.00V" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelCurrent0" Grid.Column="3" Text=" 00.00A" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ChannelIndicator1" Width="16" Height="16" Background="#FF00C800" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelLabel1" Grid.Column="1" Text="CH-B :" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelVoltage1" Grid.Column="2" Text=" 00.00V" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelCurrent1" Grid.Column="3" Text=" 00.00A" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ChannelIndicator2" Width="16" Height="16" Background="#FF00C800" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelLabel2" Grid.Column="1" Text="CH-C :" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelVoltage2" Grid.Column="2" Text=" 00.00V" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelCurrent2" Grid.Column="3" Text=" 00.00A" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ChannelIndicator3" Width="16" Height="16" Background="#FF00C800" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelLabel3" Grid.Column="1" Text="CH-D :" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelVoltage3" Grid.Column="2" Text=" 00.00V" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelCurrent3" Grid.Column="3" Text=" 00.00A" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ChannelIndicator4" Width="16" Height="16" Background="#FF00C800" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelLabel4" Grid.Column="1" Text="CH-E :" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelVoltage4" Grid.Column="2" Text=" 00.00V" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelCurrent4" Grid.Column="3" Text=" 00.00A" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Grid.Row="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ChannelIndicator5" Width="16" Height="16" Background="#FF00C800" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelLabel5" Grid.Column="1" Text="CH-F :" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelVoltage5" Grid.Column="2" Text=" 00.00V" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChannelCurrent5" Grid.Column="3" Text=" 00.00A" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border x:Name="TemperatureSection" Grid.Row="1" Grid.Column="1" Background="#FF0A0A0A" Margin="0,0,0,12">
                                <Canvas x:Name="TemperatureCanvas" Width="120" Height="207" ClipToBounds="True">
                                    <TextBlock x:Name="CableLabelText" Canvas.Left="19" Canvas.Top="17" Width="68" TextAlignment="Center" Text="Cable" FontSize="20" Foreground="White"/>
                                    <TextBlock x:Name="CableTempUnitText" Canvas.Left="19" Canvas.Top="45" Width="68" TextAlignment="Center" Text="TMP (C)" FontSize="20" Foreground="White"/>
                                    <TextBlock x:Name="CableTempValue" Canvas.Left="19" Canvas.Top="73" Width="84" Text="0.00" FontSize="22" FontFamily="Consolas" Foreground="White"/>
                                    <TextBlock x:Name="BoardLabelText" Canvas.Left="19" Canvas.Top="111" Width="68" TextAlignment="Center" Text="Board" FontSize="20" Foreground="White"/>
                                    <TextBlock x:Name="BoardTempUnitText" Canvas.Left="19" Canvas.Top="139" Width="68" TextAlignment="Center" Text="TMP (C)" FontSize="20" Foreground="White"/>
                                    <TextBlock x:Name="BoardTempValue" Canvas.Left="19" Canvas.Top="167" Width="84" Text="0.00" FontSize="22" FontFamily="Consolas" Foreground="White"/>
                                </Canvas>
                            </Border>

                            <Border x:Name="TotalPowerSection" Grid.Row="2" Grid.Column="0" Background="#FF0A0A0A" Margin="0,0,12,0">
                                <TextBlock x:Name="TotalPowerValue" Text="Total Power : 0.00W" FontSize="22" FontFamily="Consolas" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>

                            <Border x:Name="FanStatusPanel" Grid.Row="2" Grid.Column="1" Background="#FF202020">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="FanLabelText" Text="FAN" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="FanStatusText" Text="OFF" FontSize="22" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Viewbox>

            <Border Grid.Column="1" Background="#FF1E1E1E" BorderBrush="#FF3A3A3A" BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Customize Preview" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Use ARGB or RGB hex values like #FF202020 or #202020." Margin="0,6,0,12" Foreground="#FFD0D0D0" TextWrapping="Wrap"/>

                        <TextBlock Text="Section Colors" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Title background" Margin="0,10,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TitleBackgroundBox" Text="#FF5A5A5A"/>
                        <TextBlock Text="Title left text color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TitleLeftColorBox" Text="#FF5CFF5C"/>
                        <TextBlock Text="Title right text color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TitleRightColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="Channel section background" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="ChannelBackgroundBox" Text="#FF202020"/>
                        <TextBlock Text="Channel label color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="ChannelLabelColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="Voltage value color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="VoltageTextColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="Voltage warning color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="VoltageWarningColorBox" Text="#FFFFA500"/>
                        <TextBlock Text="Current value color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="CurrentTextColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="Current warning color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="CurrentWarningColorBox" Text="#FFFFA500"/>
                        <TextBlock Text="Current alert color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="CurrentAlertColorBox" Text="#FFFF0000"/>
                        <TextBlock Text="Current low-balance color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="CurrentLowColorBox" Text="#FF1E8AFF"/>
                        <TextBlock Text="Temperature section background" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TemperatureBackgroundBox" Text="#FF0A0A0A"/>
                        <TextBlock Text="Temperature label color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TemperatureLabelColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="Cable label color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="CableLabelColorBox" Text=""/>
                        <TextBlock Text="Board label color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="BoardLabelColorBox" Text=""/>
                        <TextBlock Text="TMP text color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TemperatureUnitColorBox" Text=""/>
                        <TextBlock Text="Temperature value color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TemperatureValueColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="Temperature warning color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TemperatureWarningColorBox" Text="#FFFFA500"/>
                        <TextBlock Text="Temperature alert color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TemperatureAlertColorBox" Text="#FFFF0000"/>
                        <TextBlock Text="Temperature text offsets (pixels)" Margin="0,12,0,2" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Text="Cable label offset X,Y" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CableLabelOffsetXBox" Grid.Column="0" Text="0"/>
                            <TextBox x:Name="CableLabelOffsetYBox" Grid.Column="2" Text="0"/>
                        </Grid>
                        <TextBlock Text="Cable TMP offset X,Y" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CableUnitOffsetXBox" Grid.Column="0" Text="0"/>
                            <TextBox x:Name="CableUnitOffsetYBox" Grid.Column="2" Text="0"/>
                        </Grid>
                        <TextBlock Text="Cable value offset X,Y" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CableValueOffsetXBox" Grid.Column="0" Text="0"/>
                            <TextBox x:Name="CableValueOffsetYBox" Grid.Column="2" Text="0"/>
                        </Grid>
                        <TextBlock Text="Board label offset X,Y" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BoardLabelOffsetXBox" Grid.Column="0" Text="0"/>
                            <TextBox x:Name="BoardLabelOffsetYBox" Grid.Column="2" Text="0"/>
                        </Grid>
                        <TextBlock Text="Board TMP offset X,Y" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BoardUnitOffsetXBox" Grid.Column="0" Text="0"/>
                            <TextBox x:Name="BoardUnitOffsetYBox" Grid.Column="2" Text="0"/>
                        </Grid>
                        <TextBlock Text="Board value offset X,Y" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BoardValueOffsetXBox" Grid.Column="0" Text="0"/>
                            <TextBox x:Name="BoardValueOffsetYBox" Grid.Column="2" Text="0"/>
                        </Grid>
                        <TextBlock Text="Total power section background" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TotalPowerBackgroundBox" Text="#FF0A0A0A"/>
                        <TextBlock Text="Total power text color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TotalPowerTextColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="Total power warning color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TotalPowerWarningColorBox" Text="#FFFFA500"/>
                        <TextBlock Text="Total power alert color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TotalPowerAlertColorBox" Text="#FFFF0000"/>
                        <TextBlock Text="Fan ON background" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="FanOnBackgroundBox" Text="#FF00C800"/>
                        <TextBlock Text="Fan OFF background" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="FanOffBackgroundBox" Text="#FF202020"/>
                        <TextBlock Text="Fan ON text color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="FanOnTextColorBox" Text="#FF000000"/>
                        <TextBlock Text="Fan OFF text color" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="FanOffTextColorBox" Text="#FFFFFFFF"/>
                        <TextBlock Text="MCU font ID (1,2,4,6,7,8)" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="DisplayFontIdBox" Text="4"/>

                        <TextBlock Text="Static Text" Margin="0,16,0,0" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Title left" Margin="0,10,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TitleLeftTextBox" Text="WING STUDIO"/>
                        <TextBlock Text="Title right" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TitleRightTextBox" Text="12V-2X6 Ti"/>
                        <TextBlock Text="Protection left text" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="ProtectionLeftTextBox" Text="PROTECTION"/>
                        <TextBlock Text="Protection right text" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="ProtectionRightTextBox" Text="TRIGGERED"/>
                        <TextBlock Text="Channel labels (comma separated)" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="ChannelLabelsBox" Text="CH-A,CH-B,CH-C,CH-D,CH-E,CH-F" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="52"/>
                        <TextBlock Text="Cable label" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="CableLabelBox" Text="Cable"/>
                        <TextBlock Text="Board label" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="BoardLabelBox" Text="Board"/>
                        <TextBlock Text="Temperature unit text" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TemperatureUnitBox" Text="TMP (C)"/>
                        <TextBlock Text="Total power label" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="TotalPowerLabelBox" Text="Total Power :"/>
                        <TextBlock Text="Fan label" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="FanLabelBox" Text="FAN"/>
                        <TextBlock Text="Fan ON text" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="FanOnTextBox" Text="ON"/>
                        <TextBlock Text="Fan OFF text" Margin="0,8,0,2" Foreground="#FFD0D0D0"/>
                        <TextBox x:Name="FanOffTextBox" Text="OFF"/>

                        <TextBlock x:Name="CustomizationMessageText" Margin="0,12,0,0" Foreground="#FFFFB000" TextWrapping="Wrap" Visibility="Collapsed"/>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Apply" Click="ApplyCustomizationButton_Click" Padding="10,6"/>
                            <Button Grid.Column="2" Content="Reset" Click="ResetCustomizationButton_Click" Padding="10,6"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>